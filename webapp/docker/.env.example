############
# stellar8004 - Self-hosted Supabase Configuration
#
# Option C: Supabase internal only, SvelteKit is the public face.
#
# To generate secrets: sh ./utils/generate-keys.sh --update-env
# To generate asymmetric keys: sh ./utils/add-new-auth-keys.sh --update-env
#
# REQUIRED-marker convention:
#   Every value in this template that says <<REQUIRED>> must be replaced
#   before the stack will start. Run `grep -n '<<REQUIRED>>' .env` after
#   copying this file to .env - the grep should return zero matches when
#   the file is ready for production. The migrate container's vault setup
#   also fails loudly if the indexer secret was not substituted.
############

# Postgres
POSTGRES_PASSWORD=<<REQUIRED>>

# JWT
JWT_SECRET=<<REQUIRED>>
ANON_KEY=<<REQUIRED>>
SERVICE_ROLE_KEY=<<REQUIRED>>

# ES256 asymmetric keys (generate with: sh ./utils/add-new-auth-keys.sh)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

# Dashboard
DASHBOARD_USERNAME=stellar8004admin
DASHBOARD_PASSWORD=<<REQUIRED>>

# Internal encryption
# REALTIME_DB_ENC_KEY must be exactly 16 characters (AES-128-ECB).
# generate-keys.sh produces this automatically via: openssl rand -hex 8
REALTIME_DB_ENC_KEY=<<REQUIRED>>
SECRET_KEY_BASE=<<REQUIRED>>
VAULT_ENC_KEY=<<REQUIRED>>
PG_META_CRYPTO_KEY=<<REQUIRED>>

# Analytics
LOGFLARE_PUBLIC_ACCESS_TOKEN=<<REQUIRED>>
LOGFLARE_PRIVATE_ACCESS_TOKEN=<<REQUIRED>>

# Storage S3
S3_PROTOCOL_ACCESS_KEY_ID=<<REQUIRED>>
S3_PROTOCOL_ACCESS_KEY_SECRET=<<REQUIRED>>

# URLs (Option C: internal only)
SUPABASE_PUBLIC_URL=http://kong:8000
API_EXTERNAL_URL=http://kong:8000
SITE_URL=https://stellar8004.com

# Database
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Supavisor
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=<<REQUIRED>>
POOLER_DB_POOL_SIZE=5

# Studio
STUDIO_DEFAULT_ORGANIZATION=stellar8004
STUDIO_DEFAULT_PROJECT=8004scan

# Auth - DISABLED (required by Supabase internals but all signup methods off)
JWT_EXPIRY=3600
ADDITIONAL_REDIRECT_URLS=
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"
DISABLE_SIGNUP=true
ENABLE_EMAIL_SIGNUP=false
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=noreply@stellar8004.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=unused
SMTP_PASS=unused
SMTP_SENDER_NAME=8004scan

# Edge Functions
FUNCTIONS_VERIFY_JWT=false

# PostgREST
PGRST_DB_SCHEMAS=public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

# Analytics
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# Kong
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# Storage
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub
MINIO_ROOT_USER=supa-storage
MINIO_ROOT_PASSWORD=<<REQUIRED>>

# imgproxy
IMGPROXY_AUTO_WEBP=true

# Indexer
INDEXER_SECRET=<<REQUIRED>>
# "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# Required when STELLAR_NETWORK=mainnet:
# STELLAR_MAINNET_RPC_URL=https://mainnet.sorobanrpc.com
# IDENTITY_REGISTRY=CCSMX3YEKU7IZCZSLORUCX6MQEOV6WXWAGTOJZG5YITEBAEH2Q5JY4XE
# REPUTATION_REGISTRY=CCIZJXEVL2DJXH772F7SX262M5SF7JNOIAROW2M7I6VTPOVCJ7KKM5HT
# VALIDATION_REGISTRY=CAI3ZKBNXC52F2DCEX2XQLXUTRAQKCPWUUXDELW5SPAF4GAW4HCQ4JT3
# DEPLOY_LEDGER=62001391
